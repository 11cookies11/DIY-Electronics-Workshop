SECONDME_CLIENT_ID=your_client_id
SECONDME_CLIENT_SECRET=your_client_secret
SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback
SECONDME_SCOPES=user.info chat
SECONDME_API_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_OAUTH_URL=https://go.second.me/oauth/
SECONDME_CHAT_MODEL=your_secondme_chat_model
# 可选：为 intake 结构化理解单独指定一个更强的思考型模型
# SECONDME_INTAKE_REASONING_MODEL=your_reasoning_model
SECONDME_OPENAI_BASE_URL=https://api.mindverse.com/gate/lab
# Optional: persisted admin binding token path for platform-wide Second Me access.
# SECONDME_TOKEN_STORE_PATH=.secondme/admin-token.json
# Optional: if your OpenAI-compatible endpoint differs from /v1/chat/completions
# SECONDME_CHAT_COMPLETIONS_URL=https://api.mindverse.com/gate/lab/v1/chat/completions
# Optional: server-to-server key. If omitted, the intake agent will use the signed-in OAuth access token.
# SECONDME_CHAT_API_KEY=your_chat_api_key

# LLM-first intake (recommended for DeepSeek production)
# INTAKE_LLM_FIRST_MODE=true
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-chat
# DEEPSEEK_INTAKE_CHAT_MODEL=deepseek-chat
# DEEPSEEK_INTAKE_REASONING_MODEL=deepseek-chat

# Generic aliases (optional, same effect as DeepSeek vars above)
# LLM_API_KEY=your_llm_api_key
# LLM_BASE_URL=https://your-openai-compatible-endpoint
# LLM_CHAT_MODEL=your_chat_model
# LLM_INTAKE_CHAT_MODEL=your_intake_chat_model
# LLM_INTAKE_REASONING_MODEL=your_intake_reasoning_model
# LLM_CHAT_COMPLETIONS_URL=https://your-openai-compatible-endpoint/chat/completions
